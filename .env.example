# =============================================================================
# Binance Future ETL - Environment Configuration
# =============================================================================
# IMPORTANT: This file contains sensitive credentials. NEVER commit to git!

# =============================================================================
# BINANCE API CREDENTIALS (REQUIRED)
# =============================================================================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# =============================================================================
# ETL CONFIGURATION
# =============================================================================
PRICE_THRESHOLD=10
TARGET_QUOTE=USDT

# =============================================================================
# DATA STORAGE SETTINGS
# =============================================================================
DATA_OUTPUT_DIR=data/binance_future

# =============================================================================
# GOOGLE DRIVE OAUTH 2.0 CONFIGURATION
# =============================================================================
# Google Drive folder ID where files will be uploaded
# You can find this ID in the URL when viewing the folder in Google Drive:
# https://drive.google.com/drive/folders/[FOLDER_ID]
GOOGLE_DRIVE_FOLDER_ID=

# OAuth 2.0 Client Credentials (from Google Cloud Console)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth tokens (will be populated after first authentication)
# These are automatically managed by the application
GOOGLE_REFRESH_TOKEN=

# =============================================================================
# LOGGING SETTINGS
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
