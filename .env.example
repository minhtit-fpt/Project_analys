# =============================================================================
# Binance Future ETL - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# BINANCE API CREDENTIALS (REQUIRED)
# =============================================================================
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
# WARNING: Never commit your actual API keys to version control!

BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# =============================================================================
# ETL CONFIGURATION (OPTIONAL - defaults shown)
# =============================================================================
# Price filter: Only fetch coins with price <= this value (in USDT)
PRICE_THRESHOLD=10

# Quote currency filter: Only fetch pairs ending with this quote
TARGET_QUOTE=USDT

# =============================================================================
# DATA STORAGE SETTINGS (OPTIONAL)
# =============================================================================
# Directory for storing output CSV files
DATA_OUTPUT_DIR=data/binance_future

# =============================================================================
# LOGGING SETTINGS (OPTIONAL)
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output directory
LOG_DIR=logs
