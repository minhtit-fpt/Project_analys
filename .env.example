# =============================================================================
# Binance Future ETL - Environment Configuration
# =============================================================================
# IMPORTANT: This file contains sensitive credentials. NEVER commit to git!

# =============================================================================
# BINANCE API CREDENTIALS (REQUIRED)
# =============================================================================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# =============================================================================
# ETL CONFIGURATION
# =============================================================================
PRICE_THRESHOLD=10
TARGET_QUOTE=USDT

# =============================================================================
# DATA STORAGE SETTINGS
# =============================================================================
DATA_OUTPUT_DIR=data/binance_future

# =============================================================================
# GOOGLE CLOUD STORAGE (GCS) CONFIGURATION
# =============================================================================
# GCS bucket name where files will be uploaded
GCS_BUCKET_NAME=

# Optional virtual folder prefix inside the bucket (e.g. "binance_data/")
# Leave empty to store files at the bucket root
GCS_FOLDER_PREFIX=

# Path to the GCS service account JSON key file
# Create a service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Then create and download a JSON key for that service account
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# LOGGING SETTINGS
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
